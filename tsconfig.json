{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node"]
  },
  "include": [
    "eslint.config.js",
    "prettier.config.js",
    "playwright.config.ts",
    "vitest.workspace.ts",
    "scripts/**/*.mjs",
    "tests/**/*.ts"
  ]
}
