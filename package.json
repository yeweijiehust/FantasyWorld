{
  "name": "fantasy-world",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0 <25",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter @fantasy-world/api --filter @fantasy-world/web dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "test": "pnpm -r --if-present test",
    "test:e2e": "playwright test",
    "check:render": "node scripts/check-render-build.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "pnpm --filter @fantasy-world/api db:generate",
    "db:migrate": "pnpm --filter @fantasy-world/api db:migrate",
    "auth:hash": "pnpm --filter @fantasy-world/api auth:hash",
    "keys:rotate": "pnpm --filter @fantasy-world/api keys:rotate"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.0",
    "@types/node": "^25.9.3",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@10.27.0"
}
